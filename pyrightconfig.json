{
  "include": ["pipeline"],
  "exclude": ["**/__pycache__", "**/node_modules", "**/.*", "**/*.egg-info", "**/.venv"],
  "reportMissingImports": false,
  "reportMissingModuleSource": false,
  "reportGeneralTypeIssues": false,
  "typeCheckingMode": "basic",
  "pythonVersion": "3.12",
  "executionEnvironments": [
    {
      "root": ".",
      "extraPaths": ["."]
    }
  ]
}
