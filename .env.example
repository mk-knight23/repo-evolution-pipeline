# OmniRoute AI gateway (tier-0 — free provider fallback chain)
# Start OmniRoute locally: npx omniroute  →  http://localhost:20128
OMNIROUTE_ENABLED=0
OMNIROUTE_BASE_URL=http://localhost:20128/v1
OMNIROUTE_API_KEY=omniroute

# LLM provider credentials
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=

# DashScope optional multi-key routing
DASHSCOPE_API_KEYS=
DASHSCOPE_OPENAI_URL=https://coding-intl.dashscope.aliyuncs.com/v1
DASHSCOPE_ANTHROPIC_URL=https://coding-intl.dashscope.aliyuncs.com/apps/anthropic

# GitHub source access
GITHUB_TOKEN=ghp_...
GITHUB_ORG=mk-knight23

# GitLab publish target
GITLAB_TOKEN=glpat-...
GITLAB_URL=https://gitlab.com
GITLAB_GROUP=mk-knight23-mobile

# Optional external state integration
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=eyJ...

# Optional queue and distributed processing
REDIS_URL=redis://localhost:6379

# Pipeline verification and repair flags
PIPELINE_VERIFY=0
PIPELINE_VERIFY_STRICT=0
PIPELINE_VERIFY_WEB_EXPORT=0
PIPELINE_BLOCK_PUSH_ON_VERIFY_FAIL=1
PIPELINE_REPAIR=0
PIPELINE_REPAIR_ATTEMPTS=1

# Circuit breaker thresholds
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_SECONDS=60
